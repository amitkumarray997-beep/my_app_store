{
  "expo": {
    "name": "AppStore",
    "slug": "appstore-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FAF9F6",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF9F6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.antigravity.appstore"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF9F6",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.antigravity.appstore"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "72a30dd7-b9e6-40fa-a6ca-5496ffb911f7"
      }
    }
  }
}
